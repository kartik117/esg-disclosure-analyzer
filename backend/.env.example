# Frontend origins allowed to call this API
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LLM-backed RAG assistant configuration
LLM_ENABLED=false
LLM_PROVIDER=gemini
LLM_MODEL=gemini-2.5-flash
GEMINI_API_KEY=
GEMINI_BASE_URL=
LLM_TIMEOUT_SECONDS=30

# Retrieval settings
RAG_TOP_K=5
